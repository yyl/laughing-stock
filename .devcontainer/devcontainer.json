{
  "name": "coding-workspace",
  "image": "yyl/dev-tools:latest",
  "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces/coding,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/coding",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml",
        "saoudrizwan.claude-dev",
        "rooveterinaryinc.roo-cline",
        "sst-dev.opencode",
        "thanhtunguet.qwen-code-vscode"
      ]
    }
  },
  "remoteUser": "vscode"
}
